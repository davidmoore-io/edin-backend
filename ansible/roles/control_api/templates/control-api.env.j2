# {{ ansible_managed }}
# Control API environment — generated from Ansible vault

# Domain
SSG_DOMAIN={{ edin_domain }}
SSG_CONTROL_API_DOMAIN={{ edin_domain }}
SSG_CONTROL_BOT_DOMAIN={{ edin_domain }}
SSG_HTTP_ADDR=:8080
SSG_MCP_ADDR=:8081
SSG_HTTP_API_KEY={{ vault_http_api_key }}

# Claude AI
ANTHROPIC_API_KEY={{ vault_anthropic_api_key }}

# Discord
DISCORD_BOT_TOKEN={{ vault_discord_bot_token }}
DISCORD_APP_ID={{ discord_app_id }}
DISCORD_PUBLIC_KEY={{ vault_discord_public_key }}

# Memgraph (Docker network)
MEMGRAPH_ENABLED=true
MEMGRAPH_HOST={{ memgraph_host }}
MEMGRAPH_PORT={{ memgraph_port }}

# EDIN TimescaleDB (Docker network)
EDIN_DB_ENABLED=true
EDIN_DB_HOST={{ edin_db_host }}
EDIN_DB_PORT={{ edin_db_port }}
EDIN_DB_USER=edin_writer
EDIN_DB_PASSWORD={{ vault_edin_db_password }}
EDIN_DB_NAME=edin

# EDDN TimescaleDB (Docker network)
EDDN_RAW_DB_ENABLED=true
EDDN_RAW_DB_HOST={{ eddn_db_host }}
EDDN_RAW_DB_PORT={{ eddn_db_port }}
EDDN_RAW_DB_USER=eddn_admin
EDDN_RAW_DB_PASSWORD={{ vault_eddn_db_password }}
EDDN_RAW_DB_NAME=eddn_raw

# Redis (Docker network)
CONVO_HISTORY_BACKEND=redis
CONVO_HISTORY_REDIS_ADDR=edin-redis:6379
CONVO_HISTORY_TTL=24h
CONVO_HISTORY_MAX_MESSAGES=20

# Kaine Portal auth (Authentik)
KAINE_AUTH_ENABLED={{ kaine_auth_enabled }}
KAINE_AUTH_JWKS_URL={{ kaine_auth_jwks_url }}
KAINE_AUTH_ISSUER={{ kaine_auth_issuer }}
KAINE_AUTH_AUDIENCE={{ kaine_auth_audience }}

# Galaxy data (served by Caddy)
GALAXY_DATA_DIR={{ galaxy_exporter_output_dir }}

# LLM
LLM_MAX_TOOL_ITERATIONS=5
