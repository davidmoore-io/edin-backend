[Unit]
Description=SSG Control API
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ control_api_root_dir }}
ExecStart=/usr/bin/docker compose -f {{ control_api_compose_path }} up -d --build --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ control_api_compose_path }} down
ExecReload=/usr/bin/docker compose -f {{ control_api_compose_path }} restart

[Install]
WantedBy=multi-user.target


