# {{ ansible_managed }}
services:
  control-api:
    build:
      context: {{ control_api_src_dir }}
      dockerfile: docker/control-api.Dockerfile
    container_name: control-api
    restart: unless-stopped
    env_file:
      - {{ control_api_env_file }}
    networks:
      - {{ edin_app_network }}
      - {{ edin_data_network }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 256M

networks:
  {{ edin_app_network }}:
    external: true
  {{ edin_data_network }}:
    external: true
